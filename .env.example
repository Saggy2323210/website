# MERN Deployment Environment Variables

# ===== SERVER (Backend) =====
# Copy this to server/.env

PORT=5000
NODE_ENV=production

# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT Secrets (generate random strings - use: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here_change_this
ADMIN_JWT_SECRET=your_admin_jwt_secret_here_change_this

# Admin Gate Token (for accessing /campus-control-room)
ADMIN_GATE_TOKEN=your_gate_token_here

# Auto-seed pages on startup (set to false in production)
ADMIN_AUTO_SEED=false

# CORS Origin (update with your Vercel URL after deployment)
CORS_ORIGIN=https://ssgmce-website.vercel.app

# Default Admin Account (create on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_secure_password
ADMIN_NAME=Admin

# ===== CLIENT (Frontend) =====
# Copy this to .env.local in client folder (or set in Vercel)

VITE_BACKEND_URL=https://ssgmce-backend.onrender.com

# ===== HOW TO GENERATE SECURE SECRETS =====
# Run in terminal:
# openssl rand -base64 32
# The output is your random secret string

# ===== DEPLOYMENT CHECKLIST =====
# 1. Create MongoDB Atlas account and get connection string
# 2. Generate JWT_SECRET and ADMIN_JWT_SECRET
# 3. Create GitHub repository
# 4. Deploy server to Render with all variables
# 5. Deploy client to Vercel
# 6. Update CORS_ORIGIN with Vercel URL
# 7. Update VITE_BACKEND_URL with Render URL
# 8. Test in browser
# 9. Set up GitHub Actions webhook

# ===== TROUBLESHOOTING =====
# Backend not connecting: Check CORS_ORIGIN matches frontend URL
# Frontend 404: Check VITE_BACKEND_URL is correct
# Database errors: Verify MongoDB connection string and IP whitelist
