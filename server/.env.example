# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Optional fallback if SRV DNS lookups fail on your machine/network
MONGODB_DIRECT_URI=mongodb://<username>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/<dbname>?ssl=true&authSource=admin&replicaSet=<replica-set>&retryWrites=true&w=majority

# JWT Secret (change this to a strong random string)
JWT_SECRET=your_jwt_secret_key_change_this
ADMIN_JWT_SECRET=your_admin_jwt_secret_change_this

# Admin Gate Token (required to access /campus-control-room)
ADMIN_GATE_TOKEN=your_gate_token

# Auto-seed pages on startup
ADMIN_AUTO_SEED=true

# CORS
CORS_ORIGIN=http://localhost:3000

# Default Admin Account (created on first run if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password
ADMIN_NAME=Admin
